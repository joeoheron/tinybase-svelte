{
  "name": "svelte-tinybase",
  "version": "0.2.0",
  "description": "Svelte 5 bindings for TinyBase — rune-based reactive local-first data",
  "type": "module",
  "svelte": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/components/ui/index.d.ts",
      "svelte": "./dist/components/ui/index.js",
      "default": "./dist/components/ui/index.js"
    },
    "./dom": {
      "types": "./dist/components/dom/index.d.ts",
      "svelte": "./dist/components/dom/index.js",
      "default": "./dist/components/dom/index.js"
    },
    "./inspector": {
      "types": "./dist/components/inspector/index.d.ts",
      "svelte": "./dist/components/inspector/index.js",
      "default": "./dist/components/inspector/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && svelte-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "tinybase": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tinybase": "^5.4.3",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "runes",
    "tinybase",
    "local-first",
    "reactive",
    "offline"
  ],
  "license": "MIT"
}
